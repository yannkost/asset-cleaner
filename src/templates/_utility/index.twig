{% import '_includes/forms.twig' as forms %}

<div class="asset-cleaner-utility">
    <div class="asset-cleaner-form">
        <h2>{{ 'Select Volumes'|t('asset-cleaner') }}</h2>
        
        <div class="volume-checkboxes">
            {% for volume in volumes %}
                <div class="checkbox-wrapper">
                    {{ forms.checkbox({
                        label: volume.name,
                        name: 'volumeIds[]',
                        value: volume.id,
                        checked: true,
                        class: 'volume-checkbox'
                    }) }}
                </div>
            {% endfor %}
        </div>

        <div class="buttons">
            <button type="button" class="btn submit asset-cleaner-scan-btn">
                {{ 'Scan Now'|t('asset-cleaner') }}
            </button>
        </div>
    </div>

    <div class="asset-cleaner-loading" style="display: none;">
        <div class="spinner"></div>
        <span class="loading-text">{{ 'Scanning...'|t('asset-cleaner') }}</span>
        <div class="progress-bar-container" style="display: none;">
            <div class="progress-bar">
                <div class="progress-bar-fill"></div>
            </div>
            <div class="progress-text">0%</div>
        </div>
        <div class="asset-cleaner-queue-hint" style="display: none;">
            {{ 'The queue does not appear to be running. Make sure a queue worker is active (e.g. php craft queue/listen).'|t('asset-cleaner') }}
        </div>
    </div>

    <div class="asset-cleaner-results" style="display: none;">
        <div class="asset-cleaner-results-header">
            <h2>{{ 'Results'|t('asset-cleaner') }}</h2>
            <div class="asset-cleaner-scan-meta" style="display: none;">
                <span class="asset-cleaner-scan-time"></span>
            </div>
        </div>

        <div class="asset-cleaner-stats">
            <div class="stat-box used">
                <span class="stat-label">{{ 'Used Assets'|t('asset-cleaner') }}</span>
                <span class="stat-value used-count">0</span>
            </div>
            <div class="stat-box unused">
                <span class="stat-label">{{ 'Unused Assets'|t('asset-cleaner') }}</span>
                <span class="stat-value unused-count">0</span>
            </div>
        </div>

        <div class="asset-cleaner-results-warning">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
            </svg>
            <div>
                <strong>{{ 'Before permanently deleting'|t('asset-cleaner') }}</strong>
                <span>{{ 'We recommend downloading a ZIP backup of the assets you plan to remove first, or using "Put into Trash" as a safer alternative. Permanent deletions cannot be undone.'|t('asset-cleaner') }}</span>
            </div>
        </div>

        <div class="asset-cleaner-actions" style="display: none;">
            <h3>{{ 'Bulk Actions - All Selected Volumes'|t('asset-cleaner') }}</h3>
            
            <div class="buttons">
                <button type="button" class="btn asset-cleaner-csv-btn">
                    {{ 'Download CSV'|t('asset-cleaner') }}
                </button>
                <button type="button" class="btn asset-cleaner-zip-btn">
                    {{ 'Download ZIP'|t('asset-cleaner') }}
                </button>
                <button type="button" class="btn asset-cleaner-trash-btn">
                    {{ 'Put into Trash'|t('asset-cleaner') }}
                </button>
                <button type="button" class="btn submit asset-cleaner-delete-btn">
                    {{ 'Delete Permanently'|t('asset-cleaner') }}
                </button>
            </div>
        </div>

        <hr class="asset-cleaner-separator" style="display: none;">

        <div class="asset-cleaner-volumes-container">
        </div>
    </div>
</div>
