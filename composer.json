{
    "name": "yann/craft-asset-cleaner",
    "description": "Identify and clean up unused assets in Craft CMS",
    "type": "craft-plugin",
    "version": "1.0.1",
    "license": "MIT",
    "keywords": [
        "craft",
        "cms",
        "craftcms",
        "plugin",
        "assets",
        "cleanup",
        "unused",
        "utilities"
    ],
    "authors": [
        {
            "name": "Yann Kost",
            "email": "yann.kost@ik.me"
        }
    ],
    "support": {
        "issues": "https://github.com/yannkost/asset-cleaner/issues",
        "source": "https://github.com/yannkost/asset-cleaner"
    },
    "require": {
        "php": ">=8.2",
        "craftcms/cms": "^5.0.0"
    },
    "autoload": {
        "psr-4": {
            "yann\\assetcleaner\\": "src/"
        }
    },
    "extra": {
        "handle": "asset-cleaner",
        "name": "Asset Cleaner",
        "class": "yann\\assetcleaner\\Plugin",
        "developer": "Yann Kost",
        "developerUrl": "https://github.com/yannkost",
        "documentationUrl": "https://github.com/yannkost/asset-cleaner/blob/main/README.md",
        "changelogUrl": "https://raw.githubusercontent.com/yannkost/asset-cleaner/main/CHANGELOG.md",
        "icon": "icon.svg"
    }
}
